# Chess Insight AI - Backend Environment Configuration
# Copy this file to .env and fill in your actual values.
#
# Architecture (canonical):
#   Supabase Auth  → identity (JWTs, sign-up/login)
#   Supabase Postgres → app data (users, games, analyses) via DATABASE_URL + SQLAlchemy
#   FastAPI never uses the Supabase JS client for app data — only Auth verification.

# Security
SECRET_KEY=                                    # Required: python -c 'import secrets; print(secrets.token_urlsafe(32))'
JWT_SECRET_KEY=                                # Optional: legacy app JWT; Supabase Auth uses SUPABASE_JWT_SECRET
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=11520              # 8 days
ENVIRONMENT=development                         # development | staging | production

# CORS Origins (comma-separated)
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://127.0.0.1:3000

# --- Supabase (Auth + optional Storage) ---------------------------------------
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=                             # Dashboard → Settings → API → anon / publishable
SUPABASE_SERVICE_ROLE_KEY=                     # Dashboard → Settings → API → service_role (backend only)
SUPABASE_STORAGE_BUCKET=chess-insight-files

# Supabase JWT verification (required in production/staging)
# Dashboard → Settings → API → JWT Settings → JWT Secret
SUPABASE_JWT_SECRET=
SUPABASE_JWT_ALGORITHM=HS256
SUPABASE_JWT_AUDIENCE=authenticated

# --- Application database (Supabase PostgreSQL) -------------------------------
# Dashboard → Project Settings → Database → Connection string → URI (Direct connection)
# Production and staging should always use Supabase Postgres, not local Docker.
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.<project-ref>.supabase.co:5432/postgres?sslmode=require

# Optional mirror fields (Alembic fallback only — DATABASE_URL is canonical)
POSTGRES_SERVER=db.<project-ref>.supabase.co
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_DB=postgres
POSTGRES_PORT=5432

# --- Local Docker Postgres (development fallback only) ------------------------
# Uncomment to develop offline without Supabase Postgres. Comment out DATABASE_URL above first.
# DATABASE_URL=postgresql://chessai:chessai@localhost:5432/chessai
# POSTGRES_SERVER=localhost
# POSTGRES_USER=chessai
# POSTGRES_PASSWORD=chessai
# POSTGRES_DB=chessai
# POSTGRES_PORT=5432

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Celery beat — optional scheduled Chess.com sync (P2-AA-05)
CELERY_BEAT_ENABLED=false
CHESSCOM_SCHEDULED_SYNC_INTERVAL_MINUTES=360
CHESSCOM_SCHEDULED_SYNC_DAYS=7
CHESSCOM_SCHEDULED_SYNC_MAX_USERS_PER_RUN=50
CHESSCOM_SCHEDULED_SYNC_STAGGER_SECONDS=2

# Weekly summary email stub (P2-RT-02)
WEEKLY_EMAIL_ENABLED=false
EMAIL_DELIVERY_ENABLED=false
EMAIL_FROM_ADDRESS=
WEEKLY_EMAIL_MAX_USERS_PER_RUN=100
WEEKLY_EMAIL_STAGGER_SECONDS=2

# Proactive coaching weekly digest (P3-PC-01)
WEEKLY_DIGEST_ENABLED=false
WEEKLY_DIGEST_MAX_USERS_PER_RUN=100
WEEKLY_DIGEST_STAGGER_SECONDS=2

# Stockfish Chess Engine
STOCKFISH_PATH=/usr/games/stockfish            # Path to Stockfish binary (Linux default)
STOCKFISH_DEPTH=15
STOCKFISH_TIME=1.0

# LLM coach chat (Ollama development runtime → hosted-local vLLM → hosted fallback)
# Use `local` as the primary provider after deploying a vLLM-compatible server.
# MODEL_PROVIDER is kept for backward compatibility.
LLM_PRIMARY_PROVIDER=ollama
LLM_LOCAL_BASE_URL=http://localhost:8000/v1
LLM_LOCAL_MODEL=llama3:8b-instruct
LLM_LOCAL_API_KEY=
LLM_TIMEOUT_SECONDS=30
LLM_MAX_RETRIES=2
MODEL_PROVIDER=
OLLAMA_BASE_URL=http://localhost:11434
# Development default: MIT-licensed Phi-3 Mini (3.8B, CPU-friendly).
# Use a GPU-hosted 8B model through the `local` provider for launch-scale traffic.
OLLAMA_MODEL=phi3:mini
LLM_FALLBACK_CHAIN=ollama,local,openrouter,openai

# Optional: passwordless JWT helper (scripts/get_supabase_jwt.py)
SUPABASE_TEST_EMAIL=
SUPABASE_TEST_CHESSCOM_USERNAME=
SUPABASE_MAGIC_LINK_REDIRECT=http://localhost:3000/auth/callback
# Production Supabase dashboard must also allow https://chessrun.netlify.app/auth/callback
OPENROUTER_MODEL=google/gemma-2-9b-it:free
OPENAI_MODEL=gpt-4o-mini
OPENAI_API_KEY=
OPENROUTER_API_KEY=
OPENAI_API_BASE=https://api.openai.com/v1

# Semantic memory embeddings (P3-CM-02)
EMBEDDING_ENABLED=false
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_BATCH_SIZE=20

# File Storage
UPLOAD_DIR=./uploads
REPORTS_DIR=./reports

# Logging
LOG_LEVEL=INFO
