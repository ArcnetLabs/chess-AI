# Chess Insight AI - Backend Environment Configuration
# Copy this file to .env and fill in your actual values

# Security
SECRET_KEY=                                    # Required: Generate with: python -c 'import secrets; print(secrets.token_urlsafe(32))'
JWT_SECRET_KEY=                                # Optional: Defaults to SECRET_KEY if not set
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=11520              # 8 days
ENVIRONMENT=development                         # development | staging | production

# CORS Origins (comma-separated)
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://127.0.0.1:3000

# Supabase Configuration
# SUPABASE_URL=https://ulidwkgufvfyvxllwbqe.supabase.co # Required: Your Supabase project URL
# SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InVsaWR3a2d1ZnZmeXZ4bGx3YnFlIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NjU1MDkyNzIsImV4cCI6MjA4MTA4NTI3Mn0.oJ71gHrv-FraBZ_SPZ5NfTJM_pWDHLSXEF2-10GgKks                             # Required: Supabase anon/public key
# SUPABASE_SERVICE_ROLE_KEY=sb_publishable_xzuBQJY2I6zYbLuteZfmQw_BArHKhwY                     # Required: Supabase service role key (keep secret!)
# SUPABASE_STORAGE_BUCKET=chess-insight-files

# Supabase JWT verification (backend reads this directly to validate access
# tokens — without it the backend falls back to a slow SDK round-trip per
# request, intended only for local dev). Find it in the Supabase dashboard
# under Settings -> API -> JWT Settings.
# SUPABASE_JWT_SECRET=                                                                              # Required in production
# SUPABASE_JWT_ALGORITHM=HS256
# SUPABASE_JWT_AUDIENCE=authenticated

# Database
DATABASE_URL=                                  # Required: PostgreSQL connection string from Supabase

# PostgreSQL (optional - individual components if not using DATABASE_URL)
POSTGRES_SERVER=localhost
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_DB=postgres
POSTGRES_PORT=5432

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Stockfish Chess Engine
STOCKFISH_PATH=/usr/games/stockfish            # Path to Stockfish binary (Linux default)
STOCKFISH_DEPTH=15                             # Analysis depth
STOCKFISH_TIME=1.0                             # Time limit per position (seconds)

# OpenAI / OpenRouter API (for AI-powered insights)
OPENAI_API_KEY=                                # Optional: OpenAI API key
OPENROUTER_API_KEY=                            # Optional: OpenRouter API key
OPENAI_API_BASE=https://api.openai.com/v1     # API base URL

# File Storage
UPLOAD_DIR=./uploads
REPORTS_DIR=./reports

# Logging
LOG_LEVEL=INFO                                 # DEBUG | INFO | WARNING | ERROR
