# Chess Insight AI — Frontend Environment Configuration
# Copy this file to .env.local and fill in the values.

# ─── Backend API ─────────────────────────────────────────────────────────────
# Local development
NEXT_PUBLIC_API_URL=http://localhost:8000
# Production example:
# NEXT_PUBLIC_API_URL=https://your-backend-domain.com

# ─── Supabase ────────────────────────────────────────────────────────────────
# Both variables are safe to expose in the browser (they are publishable keys).
# Find these in: Supabase Dashboard → Project → Settings → API Keys
#
# Use the modern publishable key (sb_publishable_...) for new projects.
# The legacy anon key (JWT format) also works but publishable keys are
# preferred as they support independent rotation.
#
# NEVER add service_role / secret keys here — those must only live in
# server-side environment variables and never be sent to the browser.
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_<your-key>
