# Chess Insight AI — Frontend Environment Configuration
# Copy this file to .env.local and fill in the values.

# ─── Backend API ─────────────────────────────────────────────────────────────
# Local development
NEXT_PUBLIC_API_URL=http://localhost:8000
# Production example:
# NEXT_PUBLIC_API_URL=https://your-backend-domain.com

# ─── Supabase (must match backend/.env SUPABASE_URL) ─────────────────────────
# Dashboard → Project Settings → API Keys → Publishable key (sb_publishable_…)
# Auth is passwordless: email + Chess.com username → magic link (see /auth/login).
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_<your-key>
