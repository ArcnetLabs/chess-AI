# Production Environment Variables Template
# Copy this to .env.production and fill in your values

# ============================================================================
# DATABASE
# ============================================================================
POSTGRES_USER=chess_user
POSTGRES_PASSWORD=CHANGE_THIS_SECURE_PASSWORD_123
POSTGRES_DB=chess_ai
DATABASE_URL=postgresql://chess_user:CHANGE_THIS_SECURE_PASSWORD_123@postgres:5432/chess_ai

# ============================================================================
# REDIS
# ============================================================================
REDIS_PASSWORD=CHANGE_THIS_REDIS_PASSWORD_456
REDIS_URL=redis://:CHANGE_THIS_REDIS_PASSWORD_456@redis:6379/0

# ============================================================================
# SECURITY (CRITICAL - GENERATE NEW KEYS)
# ============================================================================
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=GENERATE_A_NEW_64_CHARACTER_RANDOM_STRING_HERE
JWT_SECRET_KEY=GENERATE_ANOTHER_64_CHARACTER_RANDOM_STRING_HERE
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ============================================================================
# STOCKFISH ENGINE
# ============================================================================
STOCKFISH_PATH=/usr/games/stockfish
STOCKFISH_DEPTH=15
STOCKFISH_TIME=1.0
STOCKFISH_THREADS=2
STOCKFISH_HASH=256

# ============================================================================
# OPENAI (OPTIONAL)
# ============================================================================
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENROUTER_API_KEY=

# ============================================================================
# APPLICATION
# ============================================================================
ENVIRONMENT=production
LOG_LEVEL=INFO
PROJECT_NAME=Chess Insight AI
VERSION=1.0.0

# ============================================================================
# CORS (Update with your actual frontend domain)
# ============================================================================
BACKEND_CORS_ORIGINS=https://your-frontend-domain.com,https://www.your-frontend-domain.com

# ============================================================================
# FRONTEND
# ============================================================================
NEXT_PUBLIC_API_URL=https://your-backend-domain.com

# ============================================================================
# SUPABASE (If using Supabase instead of local PostgreSQL)
# ============================================================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ============================================================================
# MONITORING (OPTIONAL)
# ============================================================================
SENTRY_DSN=
SENTRY_ENVIRONMENT=production

# ============================================================================
# NOTES
# ============================================================================
# 1. NEVER commit this file to git
# 2. Generate new SECRET_KEY and JWT_SECRET_KEY for production
# 3. Use strong passwords for database and Redis
# 4. Update CORS origins with your actual domain
# 5. Keep this file secure and backed up
