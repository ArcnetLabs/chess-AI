# Production Environment Variables Template
# Copy to Render dashboard env vars (or a local .env.production — never commit secrets).

# ============================================================================
# ENVIRONMENT
# ============================================================================
ENVIRONMENT=production
LOG_LEVEL=INFO

# ============================================================================
# SUPABASE (Auth + PostgreSQL — canonical production stack)
# ============================================================================
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=                     # Backend only — never expose to frontend
SUPABASE_JWT_SECRET=                           # Dashboard → Settings → API → JWT Secret
SUPABASE_JWT_ALGORITHM=HS256
SUPABASE_JWT_AUDIENCE=authenticated
SUPABASE_STORAGE_BUCKET=chess-insight-files

# App database — Supabase Postgres connection string (Direct connection, port 5432)
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.<project-ref>.supabase.co:5432/postgres?sslmode=require

# ============================================================================
# REDIS (Render Redis or Upstash — required for Celery + cache)
# ============================================================================
REDIS_HOST=
REDIS_PORT=6379
REDIS_DB=0

# ============================================================================
# SECURITY (generate fresh values per environment)
# ============================================================================
SECRET_KEY=
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ============================================================================
# STOCKFISH
# ============================================================================
STOCKFISH_PATH=/usr/games/stockfish
STOCKFISH_DEPTH=15
STOCKFISH_TIME=1.0
STOCKFISH_THREADS=2
STOCKFISH_HASH=256

# ============================================================================
# LLM (optional)
# ============================================================================
OPENAI_API_KEY=
OPENROUTER_API_KEY=
OPENAI_API_BASE=https://api.openai.com/v1

# ============================================================================
# CORS + FRONTEND
# ============================================================================
BACKEND_CORS_ORIGINS=https://your-frontend-domain.com
NEXT_PUBLIC_API_URL=https://your-backend-domain.com
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# ============================================================================
# NOTES
# ============================================================================
# 1. Production uses Supabase Postgres — do NOT provision a separate Render Postgres DB.
# 2. Set all secrets in Render → chess-insight-backend → Environment (sync: false in render.yaml).
# 3. Run `alembic upgrade head` in the Render build step against Supabase DATABASE_URL.
# 4. Never commit real credentials to git.
